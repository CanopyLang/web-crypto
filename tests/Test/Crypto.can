rsaSignAlgorithmToStringTests : Test
rsaSignAlgorithmToStringTests =
    describe "Sign.rsaSignAlgorithmToString"
        [ test "RsaPss" <|
            \() ->
                Sign.rsaSignAlgorithmToString RsaPss
                    |> Expect.equal "RSA-PSS"
        , test "RsaPkcs1" <|
            \() ->
