module Test.Crypto exposing (main, tests)

import Bytes exposing (Bytes)
import Crypto exposing (Error(..))
import Crypto.Hash as Hash exposing (HashAlgorithm(..))
import Crypto.Hmac as Hmac
import Crypto.Encrypt as Encrypt exposing (AesAlgorithm(..), AesKeyLength(..), RsaKeyLength(..))
import Crypto.Sign as Sign exposing (EcCurve(..), RsaSignAlgorithm(..))
import Crypto.Key as Key exposing (KeyFormat(..))
import Expect
import Task exposing (Task)
import Test exposing (..)
import Test exposing (TestError(..))


main : Test
main =
    tests


tests : Test
tests =
    describe "Crypto"
        [ errorToStringTests
        , hashAlgorithmToStringTests
        , aesAlgorithmToStringTests
        , aesKeyLengthBitsTests
        , rsaKeyLengthBitsTests
        , ecCurveToStringTests
        , rsaSignAlgorithmToStringTests
        , keyFormatToStringTests
        , encryptedDataStructureTests
        , pbkdf2ConfigTests
        , hkdfConfigTests
        , algorithmCoverageTests
        , randomOperationTests
        , hashOperationTests
        , hmacOperationTests
        , encryptOperationTests
        , signOperationTests
        , keyOperationTests
        ]


errorToStringTests : Test
errorToStringTests =
    describe "errorToString"
        [ test "OperationFailed includes message" <|
            \() ->
                Crypto.errorToString (OperationFailed "digest failed")
                    |> Expect.equal "Operation failed: digest failed"
        , test "OperationFailed with empty message" <|
            \() ->
                Crypto.errorToString (OperationFailed "")
                    |> Expect.equal "Operation failed: "
        , test "InvalidKey includes message" <|
            \() ->
                Crypto.errorToString (InvalidKey "wrong format")
                    |> Expect.equal "Invalid key: wrong format"
        , test "InvalidKey with empty message" <|
            \() ->
                Crypto.errorToString (InvalidKey "")
                    |> Expect.equal "Invalid key: "
        , test "InvalidData includes message" <|
            \() ->
                Crypto.errorToString (InvalidData "corrupt ciphertext")
                    |> Expect.equal "Invalid data: corrupt ciphertext"
        , test "InvalidData with empty message" <|
            \() ->
                Crypto.errorToString (InvalidData "")
                    |> Expect.equal "Invalid data: "
        , test "NotSupported includes message" <|
            \() ->
                Crypto.errorToString (NotSupported "AES-XTS")
                    |> Expect.equal "Not supported: AES-XTS"
        , test "NotSupported with empty message" <|
            \() ->
                Crypto.errorToString (NotSupported "")
                    |> Expect.equal "Not supported: "
        , test "OperationFailed preserves special characters" <|
            \() ->
                Crypto.errorToString (OperationFailed "error: code=42")
                    |> Expect.equal "Operation failed: error: code=42"
        , test "InvalidKey preserves multiword message" <|
            \() ->
                Crypto.errorToString (InvalidKey "key too short for AES-256")
                    |> Expect.equal "Invalid key: key too short for AES-256"
        ]


